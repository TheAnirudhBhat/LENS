{
  "name": "portfolio-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_EXTRA_CA_CERTS=$HOME/.ssl/netskope-ca.pem next dev -p 3002",
    "build": "NODE_EXTRA_CA_CERTS=$HOME/.ssl/netskope-ca.pem next build",
    "start": "NODE_EXTRA_CA_CERTS=$HOME/.ssl/netskope-ca.pem next start -p 3002",
    "lens": "NODE_EXTRA_CA_CERTS=$HOME/.ssl/netskope-ca.pem next build && NODE_EXTRA_CA_CERTS=$HOME/.ssl/netskope-ca.pem next start -p 3002",
    "lens:dev": "NODE_EXTRA_CA_CERTS=$HOME/.ssl/netskope-ca.pem next dev -p 3002",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "kiteconnect": "^5.3.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "happy-dom": "^15.11.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
