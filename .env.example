# Copy to .env.local and fill in what you use.
# .env.local is gitignored — never commit real keys.

# Zerodha Kite Connect — live Indian holdings + LTP.
KITE_API_KEY=
KITE_API_SECRET=
# Populated automatically after the /api/kite/login flow.
KITE_ACCESS_TOKEN=

# Optional — enables LLM news tagging in /api/news.
# Without it, news falls back to keyword tagging.
ANTHROPIC_API_KEY=

# Optional — override the local data directory.
# Defaults to <home>/.claude/projects/<home-as-slug>/memory (see lib/paths.ts).
# PORTFOLIO_MEMORY_DIR=

# Optional — paths to the sibling INDmoney MCP agent (US stocks / MF detail).
# Default to <home>/claude/personal/projects/indian-stock-mcp-agent/...
# INDMONEY_MCP_JS=
# INDMONEY_BROWSER_DATA_DIR=

# Optional — extra CA bundle for corporate TLS interception (used by npm scripts).
# NODE_EXTRA_CA_CERTS=
